# ========== Database Configuration ==========
# POSTGRES_USER & POSTGRES_PASSWORD are standard for PostgreSQL container initialization
POSTGRES_USER=wingeneaiteam
POSTGRES_PAWD=thisismysecretpassword 
POSTGRES_PASSWORD=thisismysecretpassword
POSTGRES_HOST=postgresql_db
POSTGRES_PORT=5432

# Table names
CHAT_HISTORY_TABLE_NAME=chat_history

# ========== LLM API (vLLM) Configuration ==========
VLLM_PROTOCOL=http
# Generic model vLLM server address for rewrite, apology detection, and other non-QA tasks
VLLM_HOST=192.168.8.134
VLLM_PORT=25207

# Chatbot LLM Settings
LLM_NAME=/workspace/llm_model
LORA_NAME=chatbot_lora
LORA_VLLM_PROTOCOL=http
LORA_VLLM_HOST=192.168.8.134
LORA_VLLM_PORT=25207
LLM_VERSION=Gemma-3-27b-it
TEMPERATURE=0.0
MULTITURN_MODE=true
MULTITURN_CARD=false
REPHRASE_MODE=true
PATIENCES_FOR_REAL_CUSTOMER_SERVICE=3
CONTEXTS_LIMIT_SIZE=8
CHAT_HISTORY_LENGTH=2
DATASET_VERSION=2026
PROMPT_TEMPLATE=31b
API_PREFIX=chatbot
REPLACE_REFLECTION_TAGS=false

# ========== Retrieval (Qdrant & FAQ) Configuration ==========
RETRIEVAL_SCORE_THRESHOLD=0.5

# intra FAQ Retrieval
INTRA_FAQ_RETRIEVAL_PROTOCOL=http
INTRA_FAQ_RETRIEVAL_HOST=faq_retrieval
INTRA_FAQ_RETRIEVAL_PORT=6611

# DMZ FAQ Retrieval
DMZ_FAQ_RETRIEVAL_PROTOCOL=http
DMZ_FAQ_RETRIEVAL_HOST=faq_retrieval
DMZ_FAQ_RETRIEVAL_PORT=26691

# DMZ Qdrant
DMZ_QDRANT_PROTOCOL=http
DMZ_QDRANT_HOST=qdrant
DMZ_QDRANT_PORT=6333
# ========== Sensitive Keyword API Configuration ==========
SENSITIVE_KEYWORD_DETECTOR_PROTOCOL=http
SENSITIVE_KEYWORD_DETECTOR_HOST=sensitive_keyword_detector_api
SENSITIVE_KEYWORD_DETECTOR_PORT=22299
SENSITIVE_KEYWORD_VERSION=1.0.0

# ========== Log API Configuration ==========
INTRA_PG_LOGGER_PROTOCOL=http
INTRA_PG_LOGGER_HOST=log_api
INTRA_PG_LOGGER_PORT=8000

# ========== Main API Server Configuration ==========
DMZ_API_SERVER_PROTOCOL=http
DMZ_API_SERVER_HOST=ai_chatbot_api
DMZ_API_SERVER_PORT=22999

# HTTP Client
HTTP_CLIENT_TIMEOUT=60
HTTP_CLIENT_VERIFY_SSL=false

# LoggingOG_LEVEL=INFO
LOG_LEVEL=DEBUG
# ========== Frontend Configuration ==========
CHATBOT_HOST=http://192.168.8.134:22999
ASR_HOST=http://192.168.8.134:22222
TTS_HOST=http://192.168.8.134:22223
REPETITION_PENALTY=1.07

# ========== Prompt Guard Configuration =========
PROMPT_GUARD_MODE=true
PROMPT_GUARD_URL=http://prompt_guard_api:8000/classify
PROMPT_GUARD_THRESHOLD=0.9
PROMPT_GUARD_FAIL_CLOSED=false
